rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Retorna true se o usuário autenticado tiver isAdmin == true no Firestore.
    // Usa .get('isAdmin', false) para não falhar quando o campo não existe
    // (acessar .data.isAdmin diretamente retorna null se o campo for ausente,
    // e null == true é false — mas em alguns contextos pode causar erro de avaliação).
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid))
             .data.get('isAdmin', false) == true;
    }

    // ── usuarios ─────────────────────────────────────────────────────────────
    // Cada usuário lê e escreve apenas o próprio documento.
    // O ranking (TelaRanking) precisa listar todos os usuários — por isso
    // qualquer usuário autenticado pode ler a coleção inteira.
    // O admin pode atualizar APENAS o campo pontuacao de qualquer usuário
    // (necessário para o batch de recálculo em TelaAdmin).
    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pontuacao']);
    }

    // ── jogos ─────────────────────────────────────────────────────────────────
    // Qualquer usuário autenticado pode ler jogos (TelaHome, TelaPalpites, etc.).
    // Apenas o admin pode criar, atualizar ou deletar documentos de jogos.
    match /jogos/{jogoId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── palpites ──────────────────────────────────────────────────────────────
    // Usuário lê e escreve apenas os próprios palpites.
    // Admin pode ler qualquer palpite para calcular pontuação (TelaAdmin).
    match /palpites/{palpiteId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.uid || isAdmin());
      allow write: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
    }
  }
}
