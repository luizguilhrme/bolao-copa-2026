rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid))
             .data.get('isAdmin', false) == true;
    }

    // Verifica se o jogo ainda não começou (request.time é UTC, igual ao dataHora).
    // Usada nas regras de escrita de palpites para impedir alteração após o início,
    // mesmo que alguém faça chamadas diretas à API do Firestore bypassando o app.
    function jogoNaoComecou(jogoId) {
      return request.time
        < get(/databases/$(database)/documents/jogos/$(jogoId)).data.dataHora;
    }

    // ── usuarios ─────────────────────────────────────────────────────────────
    //
    // create: restringe o payload aos campos legítimos do cadastro e bloqueia
    //   qualquer tentativa de se criar já como admin ou com pontuação inflada.
    //   O campo 'uid' precisa estar no hasOnly porque toMap() o inclui.
    //
    // update: só os campos que o app permite editar; pontuacao, isAdmin,
    //   criadoEm, email e uid nunca são alterados pelo cliente —
    //   só a Cloud Function (Admin SDK) os toca, e Admin SDK ignora regras.
    //
    match /usuarios/{uid} {
      allow read: if request.auth != null;

      // Impede criar documento com isAdmin=true ou pontuação inflada.
      // Sem hasOnly: permite qualquer campo de perfil, mas bloqueia os críticos explicitamente.
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.get('isAdmin', false) == false
        && request.resource.data.get('pontuacaoClassica', 0) == 0
        && request.resource.data.get('pontuacaoCopa', 0) == 0
        && request.resource.data.get('pontuacaoEliminatorias', 0) == 0
        && request.resource.data.get('pontuacaoEspeciais', 0) == 0;

      // Apenas campos de perfil e palpites; pontuação, isAdmin, uid, email e
      // criadoEm são imutáveis pelo cliente (só o Admin SDK os toca).
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['nome', 'avatar', 'fcmToken', 'notifLembretes', 'notifRanking',
                       'palpiteCampeao', 'palpiteChuteiradeOuro', 'palpiteBoladeOuro',
                       'palpiteLuvadeOuro', 'palpiteMelhorJovem']);

      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── jogos ─────────────────────────────────────────────────────────────────
    match /jogos/{jogoId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── palpites ──────────────────────────────────────────────────────────────
    //
    // create: usuário é dono do palpite + jogo ainda não começou.
    //
    // update: todas as condições numa regra só (múltiplos allow são OR — colocar
    //   em blocos separados faria qualquer um poder alterar palpite alheio).
    //   Além de ser o dono e o jogo não ter começado, uid e jogoId não podem
    //   ser trocados (garante que o documento não é "reatribuído").
    //
    // Leitura restrita ao próprio dono: os dialogs de palpites na TelaTabela
    //   e TelaRanking foram migrados para Cloud Functions (buscarPalpitesJogo e
    //   buscarPalpitesUsuario) que rodam com Admin SDK e ignoram essas regras.
    //   Isso impede que qualquer usuário autenticado leia palpites alheios
    //   diretamente via REST API ou SDK externo.
    //
    match /palpites/{palpiteId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.uid;

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid
        && jogoNaoComecou(request.resource.data.jogoId);

      allow update: if request.auth != null
        && request.auth.uid == resource.data.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.jogoId == resource.data.jogoId
        && jogoNaoComecou(resource.data.jogoId);

      allow delete: if false;
    }

    // ── config ────────────────────────────────────────────────────────────────
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── palpites_copa ─────────────────────────────────────────────────────────
    // Um documento por usuário (ID = UID). Leitura e escrita restritas ao
    // próprio usuário. Leitura por terceiros é feita exclusivamente pela
    // Cloud Function buscarPalpitesUsuario (Admin SDK, ignora estas regras).
    match /palpites_copa/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── grupos ────────────────────────────────────────────────────────────────
    //
    // update tem dois casos permitidos:
    //   1. Usuário já é membro (sair do grupo via arrayRemove).
    //   2. Usuário está entrando: só o campo 'membros' muda, todos os membros
    //      anteriores permanecem e o uid do solicitante entra na nova lista.
    //
    // delete: só o dono — ou o último membro ao sair (que por construção é o dono).
    //
    match /grupos/{grupoId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.membros ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['membros']) &&
          request.resource.data.membros.hasAll(resource.data.membros) &&
          request.auth.uid in request.resource.data.membros
        )
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.donoUid;
    }
  }
}
