{
  "hosting": {
    "public": "build/web",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [{
    "source": "functions",
    "codebase": "default",
    "ignore": ["node_modules", ".git", "firebase-debug.log"]
  }],
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "bolaodasoci2026",
          "appId": "1:847953336398:android:d327d3ece2006e11dfcb1f",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "bolaodasoci2026",
          "configurations": {
            "android": "1:847953336398:android:d327d3ece2006e11dfcb1f"
          }
        }
      }
    }
  }
}
